{
  "name": "@thcode-society/ui-thc-library",
  "private": false,
  "version": "1.0.19",
  "description": "THC Code Component Library, Nuxt 3, SCSS, SCSS Variables, Typescript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiegoreTHC/UI.ThcLibrary.git"
  },
  "bugs": {
    "url": "https://github.com/DiegoreTHC/UI.ThcLibrary.git/issues"
  },
  "homepage": "https://github.com/DiegoreTHC/UI.ThcLibrary.git#readme",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist",
    "runtime"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "release": "npm run prepack && changelogen --release && npm publish --access public",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^3.16.2",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@nuxt/devtools": "^2.4.0",
    "@nuxt/eslint-config": "^1.3.0",
    "@nuxt/module-builder": "^1.0.1",
    "@nuxt/schema": "^3.16.2",
    "@nuxt/test-utils": "^3.17.2",
    "@thcode-society/icons": "^1.0.2",
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "changelogen": "^0.6.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-nuxt": "^4.0.0",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-vue": "^10.0.0",
    "nuxt": "^3.16.2",
    "prettier": "^3.5.3",
    "sass": "^1.89.0",
    "sass-loader": "^16.0.5",
    "stylelint": "^16.18.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-scss": "^6.11.1",
    "swiper": "^11.2.2",
    "typescript": "~5.8.3",
    "vitest": "^3.1.2",
    "vue-3-slider-component": "^1.0.1",
    "vue-tsc": "^2.2.8",
    "vue3-zoomer": "^1.0.5"
  }
}
